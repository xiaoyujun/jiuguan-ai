  "gender_detection": {
    "female_indicators": ["她", "女", "girl", "woman", "female", "姐", "妹", "小姐", "lady"],
    "male_indicators": ["他", "男", "boy", "man", "male", "哥", "弟", "先生", "guy"]
  },
  
  "sports_detection": {
    "summary_keywords": ["田径", "运动", "健将", "力量", "athletic", "sports", "runner", "fitness"],
    "tag_keywords": ["田径", "运动", "健将", "力量", "athletic", "sports", "runner", "fitness"],
    "description_indicators": ["田径", "跑步", "运动", "锻炼", "健身", "体育", "比赛", "训练"],
    "professional_words": ["田径健将", "运动员", "体育", "健将"]
  },
  
  "fuzzy_config": {
    "min_score": 60,
    "max_results": 10,
    "boost_exact": 1.5,
    "boost_partial": 1.2,
    "name_search_min_score": 30
  },
  
  "search_weights": {
    "feature_score_weight": 0.6,
    "fuzzy_score_weight": 0.3,
    "precision_bonus_weight": 0.1,
    "gender_match_boost": 1.5,
    "gender_mismatch_penalty": 0.5,
    "sports_match_boost": 2.0,
    "sports_no_match_penalty": 0.3
  },
  
  "fuzzy_weights": {
    "name_weight": 2.0,
    "summary_weight": 1.5,
    "tags_weight": 1.2,
    "description_weight": 1.0,
    "max_score_ratio": 0.6,
    "avg_score_ratio": 0.4
  },
  
  "precision_bonus": {
    "high_value_words": ["跑步", "田径", "运动", "女生", "女性", "艺术家", "冒险者"],
    "high_value_bonus": 0.2,
    "medium_value_words": ["喜欢", "阳光", "开朗", "活力", "学生", "成熟", "朋友"],
    "medium_value_bonus": 0.1,
    "default_bonus": 0.05,
    "special_combination_bonus": 0.5,
    "gender_only_bonus": 0.2,
    "professional_sports_bonus": 0.3
  },
  
  "text_processing": {
    "min_word_length": 1,
    "max_description_length": 100,
    "max_description_sentences": 3,
    "min_sentence_length": 10
  },

  "relevance_thresholds": {
    "high_relevance": 0.7,
    "medium_relevance": 0.4,
    "low_relevance": 0.1
  },

  "return_fields": {
    "high_relevance": "complete",
    "medium_relevance": {
      "include_fields": ["总结词", "关键词", "属性.状态", "属性.外貌特征", "标签", "描述"]
    },
    "low_relevance": {
      "include_fields": ["属性.状态.名称", "属性.外貌特征", "总结词"]
    }
  },

  "role_context_config": {
    "player_binding_boost": 1.5,
    "role_relationship_boost": 1.3,
    "mention_boost": 1.2,
    "enable_context_logging": true,
    "min_context_threshold": 0.05
  },

  "chat_analysis": {
    "min_relevance_threshold": 0.05,
    "direct_mention_score": 0.8,
    "max_context_characters": 8,
    "enable_role_context": true,
    "role_context_weights": {
      "player_bound_character": 1.5,
      "related_character": 1.3,
      "mentioned_character": 1.2,
      "multi_chat_bound_character": 2.0,
      "multi_chat_participant": 1.8
    },
    "multi_chat_mode": {
      "enable_enhanced_binding": true,
      "binding_boost_multiplier": 1.5,
      "participant_boost": 1.3,
      "cross_reference_boost": 1.2
    }
  },

  "dynamic_compression": {
    "max_storybooks": 15,
    "full_display_count": 4,
    "compression_levels": {
      "full": "complete",
      "medium": {
        "include_fields": ["总结词", "关键词", "属性.状态", "属性.外貌特征", "标签", "属性.状态.描述"]
      },
      "high": {
        "include_fields": ["属性.状态.名称", "属性.外貌特征", "属性.状态.描述", "属性.背包", "属性.事件"]
      },
      "extreme": {
        "include_fields": ["属性.状态.名称", "属性.外貌特征"]
      }
    },
    "size_thresholds": {
      "large_dataset": 50000,
      "medium_dataset": 20000
    }
  }
}
